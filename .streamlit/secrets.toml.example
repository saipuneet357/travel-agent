# Copy this file to secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to version control

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "YOUR_RANDOM_SECRET_KEY_HERE"

[auth.auth0]
domain = "your-domain.auth0.com"
client_id = "YOUR_AUTH0_CLIENT_ID"
client_secret = "YOUR_AUTH0_CLIENT_SECRET"
server_metadata_url = "https://your-domain.auth0.com/.well-known/openid-configuration"
